# Required
BOT_TOKEN=your-telegram-bot-token-from-botfather

# Required — comma-separated Telegram user IDs to allowlist
ALLOWED_USER_IDS=123456789,987654321

# Optional — defaults to http://localhost:4096
OPENCODE_URL=http://localhost:4096

# Optional — set to 1 to log every OpenCode SSE event at info (trace message.part.delta field / deltas)
# OPENCODE_SSE_VERBOSE=1
